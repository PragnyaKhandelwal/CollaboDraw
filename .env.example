# Copy this file to .env (ignored) and fill in your own values.
# Never commit real credentials.

## Database config (required)
## Option A (recommended): host/port/db, app builds JDBC URL internally
DB_HOST=your-host.aivencloud.com
DB_PORT=17118
DB_NAME=defaultdb
DB_USER=your_db_user
DB_PASS=your_db_password
SSL_MODE=REQUIRED

## Option B (also supported): AIVEN_* aliases
# AIVEN_HOST=your-host.aivencloud.com
# AIVEN_PORT=17118
# AIVEN_DB=defaultdb

## Google OAuth2 (required by current SecurityConfig)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

## Security (recommended to set explicitly outside local dev)
# Comma-separated list of origins allowed for CORS and the WebSocket handshake.
# Include your production URL here, e.g. https://collabodraw-bdd2.onrender.com
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080
# Random secret used to sign "remember me" cookies. Generate one, e.g.:
#   powershell -c "[Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))"
REMEMBER_ME_KEY=change-me-to-a-random-secret